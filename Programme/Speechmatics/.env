# Speechmatics API-Key
# siehe https://docs.speechmatics.com/get-started/authentication
apiKey = ""

# RTMP Source-Stream, der uebersetzt werden soll (Angabe mit rtmp://)
streamLink = "rtmp://localhost/live/transcode1080_live"

# Ordner, wo die Transcript-Dateien zwischengespeichert werden
filePath = ""

# im Stream gesprochene Sprache (zB de, en, ...)
language = "de"

# Nur benötigt bei Übersetzung in eine andere Sprache, sonst wird Ausgangssprache genommen
# Wichtig: mit "," teilen zur richtigen Spracherkennung
targetLanguages = ""

# Delay der Transkrioption, Angabe in Sekunden. (Default 4s); je höher, desto bessere Genauigkeit
# siehe https://docs.speechmatics.com/speech-to-text/realtime/output#latency
maxDelay = ""

# zu langer übersetzter Text wird in der Mitte gebrochen und die Zeit zum Warten zum Anzeigen von der zweiten Hälfte vom Text
# Angabe in Millisekunden (1000 = 1 Sekunde)
languageBreakWait = ""

# die maximale länge des Textes für die übersetzung kann variable definiert werden.
# Angabe 1 für einen Buchstaben.
translationMaxLength = ""